# SolarSage frontend (Vite) environment.
# Only PUBLIC values belong here — anything VITE_-prefixed is embedded in the
# browser bundle. Never put OPENAI_API_KEY or the service-role key here.

# Supabase project the SPA talks to. The anon key is public by design (RLS
# enforces access). Defaults to the original project if unset (see client.ts).
VITE_SUPABASE_URL=https://glgvubxgigvrczrifcuv.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# ---------------------------------------------------------------------------
# Server-side secrets (DO NOT put here / DO NOT prefix with VITE_).
# Set these with the Supabase CLI / dashboard for the edge functions:
#   supabase secrets set OPENAI_API_KEY=sk-...
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected in the managed
# runtime; set them only for local `supabase functions serve`.
# ---------------------------------------------------------------------------
